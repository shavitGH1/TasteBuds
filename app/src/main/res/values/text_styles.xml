<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Beautiful text styles for all pages -->

    <!-- Page Titles -->
    <style name="TextAppearance.TasteBuds.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#000000</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Section Headers -->
    <style name="TextAppearance.TasteBuds.SectionHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#333333</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Recipe Names -->
    <style name="TextAppearance.TasteBuds.RecipeName" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Body Text -->
    <style name="TextAppearance.TasteBuds.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">#666666</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Meta Info (time, difficulty) -->
    <style name="TextAppearance.TasteBuds.Meta" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">#888888</item>
    </style>

    <!-- Chip Text -->
    <style name="TextAppearance.TasteBuds.Chip" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

