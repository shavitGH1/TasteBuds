<?xml version="1.0" encoding="utf-8"?>
<!-- Soft rose-cream background for feed/listing pages -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Creamy rose base -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#FFF5F0"
                android:centerColor="#FFE8E0"
                android:endColor="#FFD8CC"
                android:type="linear" />
        </shape>
    </item>

    <!-- Soft blush overlay -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#25FFB6C1"
                android:centerColor="#18FFC0CB"
                android:endColor="#25FFDAB9"
                android:type="linear" />
        </shape>
    </item>
</layer-list>

