<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#FFF8F3"
                android:centerColor="#FFEEE8"
                android:endColor="#FFE4D8"
                android:type="linear" />
        </shape>
    </item>

    <!-- Semi-transparent overlay for depth -->
    <item>
        <shape>
            <gradient
                android:angle="45"
                android:startColor="#20FFB6C1"
                android:centerColor="#15F4C2C2"
                android:endColor="#20DDA0DD"
                android:type="linear" />
        </shape>
    </item>
</layer-list>

